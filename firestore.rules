rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Productos
    match /productos/{productoId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Categorías
    match /categorias/{categoriaId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Todo lo demás bloqueado
    match /{document=**} {
      allow read, write: if false;
    }
  }
}