rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Carpeta pública de productos (solo escritura autenticada)
    match /productos_caballero/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}